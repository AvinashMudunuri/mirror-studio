{
  "name": "mirror-studio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "jest",
    "test:integration": "jest tests/integration",
    "test:models": "node scripts/test-api-models.js",
    "test:bedrock-models": "node scripts/test-bedrock-models.js",
    "test:bedrock": "npm run build --workspace=@mirror/agents && node scripts/test-bedrock-connectivity.js",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "demo:episode": "npx tsx scripts/demo-sample-episode.ts",
    "real:episode": "node scripts/create-real-episode.js",
    "real:episode:dev": "SKIP_REVIEWERS=childPsychologist,gameDesigner,ethicsReviewer MAX_RUN_TOKENS=400000 node scripts/create-real-episode.js",
    "bind:script": "node scripts/compile-screenplay.js",
    "persist:run": "node scripts/persist-run.js",
    "art:ep1": "node scripts/generate-ep1-scene-art.js"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "^3.1085.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1085.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "pg": "^8.13.1",
    "ts-jest": "^29.1.2",
    "tsx": "^4.23.0",
    "turbo": "^2.10.3",
    "typescript": "^5.7.2",
    "uuid": "^11.1.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2"
}
