# Environment Configuration

# Database
DATABASE_URL=postgresql://mirror:mirror_dev_password@localhost:5432/mirror_studio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mirror_studio
POSTGRES_USER=mirror
POSTGRES_PASSWORD=mirror_dev_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Models
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
PRIMARY_LLM_MODEL=claude-sonnet-4.5
PRIMARY_LLM_TEMPERATURE=0.3
PRIMARY_LLM_MAX_TOKENS=4096

SECONDARY_LLM_MODEL=gpt-4-turbo
EMBEDDING_MODEL=text-embedding-3-large

# Claude backend: 'anthropic' (default, calls the Anthropic API directly
# using ANTHROPIC_API_KEY above) or 'bedrock' (calls the same Claude models
# via AWS Bedrock, authenticated with AWS credentials instead — no
# ANTHROPIC_API_KEY needed). See docs/decisions/004-aws-bedrock-alternative-backend.md.
CLAUDE_BACKEND=anthropic

# AWS Bedrock (only used when CLAUDE_BACKEND=bedrock). Uses the standard AWS
# credential provider chain by default — env vars below, ~/.aws/credentials,
# or an IAM role — so leave these blank if credentials are already available
# another way.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# IMPORTANT: when CLAUDE_BACKEND=bedrock, ANTHROPIC_MODEL / ANTHROPIC_REVIEW_MODEL
# / <AGENT>_MODEL overrides must use Bedrock model or inference-profile IDs
# (e.g. us.anthropic.claude-sonnet-5), NOT the direct-API model names like
# claude-sonnet-5 — these IDs are account/region-specific, look them up in the
# AWS Bedrock console rather than assuming the example above is correct.

# Application
NODE_ENV=development
PORT=3000
API_PORT=3001

# Logging
LOG_LEVEL=info

# Agent System
# (orchestration is the sequential script scripts/create-real-episode.js —
# ADR 001; there is no AGENT_ORCHESTRATOR switch, nothing ever read it)
MESSAGE_BUS_TYPE=redis_streams
MEMORY_PROVIDER=postgresql

# Feature Flags
ENABLE_DEVELOPER_AGENTS=true
ENABLE_AUTO_DEPLOYMENT=false
ENABLE_AGENT_DEBATES=true
