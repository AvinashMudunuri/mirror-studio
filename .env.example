# Environment Configuration

# Database
DATABASE_URL=postgresql://mirror:mirror_dev_password@localhost:5432/mirror_studio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mirror_studio
POSTGRES_USER=mirror
POSTGRES_PASSWORD=mirror_dev_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Models
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
PRIMARY_LLM_MODEL=claude-sonnet-4.5
PRIMARY_LLM_TEMPERATURE=0.3
PRIMARY_LLM_MAX_TOKENS=4096

SECONDARY_LLM_MODEL=gpt-4-turbo
EMBEDDING_MODEL=text-embedding-3-large

# Application
NODE_ENV=development
PORT=3000
API_PORT=3001

# Logging
LOG_LEVEL=info

# Agent System
AGENT_ORCHESTRATOR=langgraph
MESSAGE_BUS_TYPE=redis_streams
MEMORY_PROVIDER=postgresql

# Feature Flags
ENABLE_DEVELOPER_AGENTS=true
ENABLE_AUTO_DEPLOYMENT=false
ENABLE_AGENT_DEBATES=true
